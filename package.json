{
  "name": "the-tower",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @the-tower/mcp-server --filter @the-tower/api --filter @the-tower/web dev:watch",
    "dev:api": "pnpm --filter @the-tower/api dev",
    "dev:web": "pnpm --filter @the-tower/web dev",
    "dev:mcp": "pnpm --filter @the-tower/mcp-server dev:watch",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
